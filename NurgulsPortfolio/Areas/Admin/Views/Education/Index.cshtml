@model PagedResultDTO<Education>
@{
    ViewData["Title"] = "Eğitim Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<main class="ml-[240px] pt-16 h-screen overflow-y-auto">
    <div class="p-container_padding max-w-7xl mx-auto">
        <!-- Breadcrumb & Header -->
        <div class="flex justify-between items-end mb-8">
            <div>

                <h2 class="font-h1 text-h1 text-on-surface">Eğitim</h2>
            </div>
            <button class="flex items-center space-x-2 bg-primary-container text-on-primary-container px-6 py-3 rounded-xl font-bold hover:opacity-90 active:scale-95 transition-all shadow-lg shadow-primary-container/20" onclick="toggleDrawer()">
                <span class="material-symbols-outlined" data-icon="add">add</span>
                <span>Yeni Eğitim Ekle</span>
            </button>
        </div>
        <!-- Bento Layout Content / Table -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl overflow-hidden">

            @if (Model.Items != null && Model.Items.Any())
            {
                <!-- Records present - Table -->
                <div id="table-container">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-surface-container-low border-b border-outline-variant">
                                <th class="px-6 py-4 font-label-md text-label-md text-secondary">Okul/Derece</th>
                                <th class="px-6 py-4 font-label-md text-label-md text-secondary">Bölüm</th>
                                <th class="px-6 py-4 font-label-md text-label-md text-secondary">Not Ortalaması</th>
                                <th class="px-6 py-4 font-label-md text-label-md text-secondary">Tarih Aralığı</th>
                                <th class="px-6 py-4 font-label-md text-label-md text-secondary">Durum</th>
                                <th class="px-6 py-4 font-label-md text-label-md text-secondary text-right">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant">
                            @foreach (var item in Model.Items)
                            {
                                <tr class="hover:bg-surface-container-low transition-colors">
                                    <td class="px-6 py-5">
                                        <div class="flex items-center">
                                            <div class="w-10 h-10 rounded-lg bg-secondary-container flex items-center justify-center mr-4">
                                                <span class="material-symbols-outlined text-on-secondary-container" data-icon="corporate_fare">corporate_fare</span>
                                            </div>
                                            <div>
                                                <p class="font-h3 text-body-lg text-on-surface">@item.School</p>
                                                <p class="text-label-md text-secondary">@item.Degree</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <p class="font-h3 text-body-lg text-on-surface">@item.Department</p>
                                    </td>
                                    <td>
                                        <p class="font-h3 text-body-lg text-on-surface">@item.GPA</p>
                                    </td>
                                    @if (item.EndDate == null)
                                    {
                                        <td class="px-6 py-5 font-body-md text-secondary">@item.StartDate.ToShortDateString() — Günümüz</td>
                                    }
                                    else
                                    {
                                        <td class="px-6 py-5 font-body-md text-secondary">@item.StartDate.ToShortDateString() — @item.EndDate </td>
                                    }
                                    @if (item.IsActive)
                                    {
                                        <td class="px-6 py-5 font-body-md text-secondary">Aktif</td>
                                    }
                                    else
                                    {
                                        <td class="px-6 py-5 font-body-md text-secondary">Pasif</td>
                                    }

                                    <td class="px-6 py-5 text-right">
                                        <div class="flex justify-end space-x-2">
                                            <button class="p-2 text-secondary hover:text-primary hover:bg-primary-fixed rounded-lg transition-all" title="Düzenle" onclick="openEditModal(@item.Id, '@item.School', '@item.Degree', '@item.Department', '@item.GPA', '@item.StartDate.ToString("yyyy-MM-dd")', '@(item.EndDate?.ToString("yyyy-MM-dd"))')">
                                                <span class="material-symbols-outlined text-[20px]" data-icon="edit">edit</span>
                                            </button>
                                            @if (item.IsActive)
                                            {
                                                <form asp-action="MakePassive" asp-controller="Education" asp-area="Admin" method="post" class="inline">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="p-2 text-on-tertiary-fixed-variant hover:text-error transition-colors">
                                                        <span class="material-symbols-outlined">toggle_on</span>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="MakeActive" asp-controller="Education" asp-area="Admin" method="post" class="inline">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="p-2 text-on-tertiary-fixed-variant hover:text-success transition-colors">
                                                        <span class="material-symbols-outlined">toggle_off</span>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                    <div class="px-6 py-4 border-t border-outline-variant flex items-center justify-between">
                        <p class="text-on-surface-variant text-body-md">
                            Toplam @Model.TotalCount yetenek gösteriliyor.
                        </p>
                        <div class="flex gap-2">
                            @if (Model.HasPreviousPage)
                            {
                                <a href="?page=@(Model.CurrentPage - 1)"
                                   class="p-2 border border-outline-variant rounded-lg hover:bg-surface-container-high">
                                    <span class="material-symbols-outlined">chevron_left</span>
                                </a>
                            }
                            else
                            {
                                <button class="p-2 border border-outline-variant rounded-lg opacity-50" disabled>
                                    <span class="material-symbols-outlined">chevron_left</span>
                                </button>
                            }

                            @if (Model.HasNextPage)
                            {
                                <a href="?page=@(Model.CurrentPage + 1)"
                                   class="p-2 border border-outline-variant rounded-lg hover:bg-surface-container-high">
                                    <span class="material-symbols-outlined">chevron_right</span>
                                </a>
                            }
                            else
                            {
                                <button class="p-2 border border-outline-variant rounded-lg opacity-50" disabled>
                                    <span class="material-symbols-outlined">chevron_right</span>
                                </button>
                            }
                        </div>
                    </div>
                </div>

            }
            else
            {
                <!-- Empty State -->
                <div class="flex flex-col items-center justify-center py-32 px-10" id="empty-state">
                    <div class="w-64 h-64 mb-8">
                    </div>
                    <h3 class="font-h2 text-h2 text-on-surface mb-2">Henüz kayıt bulunmuyor</h3>
                    <button class="flex items-center space-x-2 border-2 border-primary-container text-primary px-8 py-3 rounded-xl font-bold hover:bg-primary-container hover:text-on-primary-container transition-all" onclick="toggleDrawer()">
                        <span class="material-symbols-outlined" data-icon="add_circle">add_circle</span>
                        <span>İlk Kaydı Ekleyin</span>
                    </button>
                </div>
            }


        </div>
    </div>
</main>
<!-- Side Slide-over Drawer Add (Form) -->
<div class="fixed inset-0 bg-on-background/40 backdrop-blur-sm z-50 hidden transition-opacity opacity-0 pointer-events-none duration-300" id="drawer-backdrop" onclick="toggleDrawer()"></div>
<div class="fixed top-0 right-0 h-full w-[480px] bg-surface-container-lowest z-[60] drawer-shadow transition-drawer transform translate-x-full" id="add-side-drawer">
    <div class="flex flex-col h-full">
        <!-- Drawer Header -->
        <div class="flex items-center justify-between px-8 py-6 border-b border-outline-variant bg-surface-container-low">
            <div>
                <h3 class="font-h2 text-h2 text-on-surface">Eğitim Bilgisi Ekle</h3>
                <p class="text-body-md text-secondary">Eğitim bilgilerinizi detaylandırın.</p>
            </div>
            <button class="p-2 text-secondary hover:text-on-surface rounded-lg hover:bg-surface-container-high transition-all" onclick="toggleDrawer()">
                <span class="material-symbols-outlined" data-icon="close">close</span>
            </button>
        </div>
        <!-- Drawer Form Body -->
        <form asp-action="AddEducation" asp-controller="Education" asp-area="Admin" method="post" class="flex flex-col flex-1 min-h-0">
            <div class="flex-1 overflow-y-auto p-8 space-y-6 min-h-0">
                <div class="space-y-2">
                    <label class="block text-label-md text-on-surface-variant">Okul Adı</label>
                    <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" name="School" placeholder="Boğaziçi" type="text" />
                </div>
                <div class="space-y-2">
                    <label class="block text-label-md text-on-surface-variant">Derece</label>
                    <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" name="Degree" placeholder="Lisans" required type="text" />
                </div>
                <div class="space-y-2">
                    <label class="block text-label-md text-on-surface-variant">Bölüm</label>
                    <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" name="Department" placeholder="Yazılım Mühendisliği" required type="text" />
                </div>
               
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="block text-label-md text-on-surface-variant">Başlangıç Tarihi</label>
                        <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" type="date" required name="StartDate" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-label-md text-on-surface-variant">Bitiş Tarihi</label>
                        <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" type="date" name="EndDate" id="EndDate" />
                    </div>
                </div>
                <div class="flex items-center space-x-3 py-2">
                    <input class="w-5 h-5 text-primary-container rounded border-outline-variant focus:ring-primary-container" id="add-current-job" type="checkbox" />
                    <label class="text-body-md text-on-surface" for="add-current-job">Halen okuyorum.</label>
                </div>
                <div class="space-y-2">
                    <label class="block text-label-md text-on-surface-variant">Not Ortalaması</label>
                    <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" name="GPA" placeholder="2.10/4" required type="text" />
                </div>

                </div>

            <!-- Drawer Footer -->
            <div class="p-8 border-t border-outline-variant bg-surface-container-low flex space-x-4">
                <button class="flex-1 px-6 py-3 border border-outline text-secondary font-bold rounded-xl hover:bg-surface-container-highest transition-all" onclick="toggleDrawer()" type="button">İptal</button>
                <button class="flex-1 px-6 py-3 bg-primary-container text-on-primary-container font-bold rounded-xl shadow-lg shadow-primary-container/20 hover:opacity-90 active:scale-95 transition-all" type="submit">Kaydet</button>
            </div>

        </form>
    </div>
</div>

<!-- Side Slide-over Drawer Edit (Form) -->

<div class="fixed top-0 right-0 h-full w-[480px] bg-surface-container-lowest z-[60] drawer-shadow transition-drawer transform translate-x-full" id="edit-side-drawer">
    <div class="flex flex-col h-full">
        <!-- Drawer Header -->
        <div class="flex items-center justify-between px-8 py-6 border-b border-outline-variant bg-surface-container-low">
            <div>
                <h3 class="font-h2 text-h2 text-on-surface">Eğitim Bilgilerini Düzenle</h3>
            </div>
            <button class="p-2 text-secondary hover:text-on-surface rounded-lg hover:bg-surface-container-high transition-all" onclick="toggleDrawer('edit-side-drawer')">
                <span class="material-symbols-outlined" data-icon="close">close</span>
            </button>
        </div>
        <!-- Drawer Form Body -->
        <form asp-action="EditEducation" asp-controller="Education" asp-area="Admin" method="post" class="flex flex-col flex-1 min-h-0">
            <div class="flex-1 overflow-y-auto p-8 space-y-6 min-h-0">
                <div class="space-y-2">
                    <input type="hidden" name="Id" id="editId" />
                    <label class="block text-label-md text-on-surface-variant">Okul Adı</label>
                    <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" name="School" id="editSchool" type="text" />
                </div>
                <div class="space-y-2">
                    <label class="block text-label-md text-on-surface-variant">Derece</label>
                    <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" name="Degree" id="editDegree" required type="text" />
                </div>
                <div class="space-y-2">
                    <label class="block text-label-md text-on-surface-variant">Bölüm</label>
                    <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" name="Department" id="editDepartment" required type="text" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="block text-label-md text-on-surface-variant">Başlangıç Tarihi</label>
                        <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" type="date" name="StartDate" required id="editStartDate" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-label-md text-on-surface-variant">Bitiş Tarihi</label>
                        <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" type="date" name="EndDate" id="editEndDate" />
                    </div>
                </div>
                <div class="flex items-center space-x-3 py-2">
                    <input class="w-5 h-5 text-primary-container rounded border-outline-variant focus:ring-primary-container" id="edit-current-job" type="checkbox" />
                    <label class="text-body-md text-on-surface" for="edit-current-job">Halen okuyorum</label>
                </div>
                <div class="space-y-2">
                    <label class="block text-label-md text-on-surface-variant">Not Ortalaması</label>
                    <input class="w-full px-4 py-3 rounded-lg border-outline-variant focus:border-primary-container focus:ring-1 focus:ring-primary-container/20 text-body-md" name="GPA" required id="editGPA" type="text" />
                </div>

            </div>

            <!-- Drawer Footer -->
            <div class="p-8 border-t border-outline-variant bg-surface-container-low flex space-x-4">
                <button class="flex-1 px-6 py-3 border border-outline text-secondary font-bold rounded-xl hover:bg-surface-container-highest transition-all" onclick="toggleDrawer('edit-side-drawer')" type="button">İptal</button>
                <button class="flex-1 px-6 py-3 bg-primary-container text-on-primary-container font-bold rounded-xl shadow-lg shadow-primary-container/20 hover:opacity-90 active:scale-95 transition-all" type="submit">Kaydet</button>
            </div>
        </form>
    </div>
</div>
<script>
           const addDrawer = document.getElementById('add-side-drawer');
    const editDrawer = document.getElementById('edit-side-drawer');
    const backdrop = document.getElementById('drawer-backdrop');
    const emptyState = document.getElementById('empty-state');
    const tableContainer = document.getElementById('table-container');

    function toggleDrawer(drawerId = 'add-side-drawer') {
        const drawer = document.getElementById(drawerId);
        const isOpen = !drawer.classList.contains('translate-x-full');

        if (isOpen) {
            drawer.classList.add('translate-x-full');
            backdrop.classList.add('opacity-0', 'pointer-events-none');
            setTimeout(() => backdrop.classList.add('hidden'), 300);
        } else {
            backdrop.classList.remove('hidden');
            setTimeout(() => {
                backdrop.classList.remove('opacity-0', 'pointer-events-none');
                drawer.classList.remove('translate-x-full');
            }, 10);
        }
    }
              document.addEventListener('DOMContentLoaded', function () {
        function toggleEndDate(checkboxId, endDateId) {
            const checkbox = document.getElementById(checkboxId);
            const endDateInput = document.getElementById(endDateId);

            if (!checkbox || !endDateInput) return; // güvenlik kontrolü

            checkbox.addEventListener('change', function () {
                if (this.checked) {
                    endDateInput.value = '';
                    endDateInput.disabled = true;
                    endDateInput.classList.add('opacity-50', 'cursor-not-allowed');
                } else {
                    endDateInput.disabled = false;
                    endDateInput.classList.remove('opacity-50', 'cursor-not-allowed');
                }
            });
        }

        toggleEndDate('add-current-job', 'EndDate');
        toggleEndDate('edit-current-job', 'editEndDate');
    });

      function saveAndShowTable() {
        toggleDrawer();
        setTimeout(() => {
            emptyState.classList.add('hidden');
            tableContainer.classList.remove('hidden');
        }, 500);
    }

              function openEditModal(id, school, degree, department, GPA, startDate, endDate) {
        document.getElementById('editId').value = id;
        document.getElementById('editSchool').value = school;
        document.getElementById('editDegree').value = degree;
        document.getElementById('editDepartment').value = department;
        document.getElementById('editGPA').value = GPA;
        document.getElementById('editStartDate').value = startDate;
        document.getElementById('editEndDate').value = endDate || '';


        const checkbox = document.getElementById('edit-current-job');
        const endDateInput = document.getElementById('editEndDate');
        if (!endDate) {
            checkbox.checked = true;
            endDateInput.disabled = true;
            endDateInput.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
            checkbox.checked = false;
            endDateInput.disabled = false;
            endDateInput.classList.remove('opacity-50', 'cursor-not-allowed');
        }

        toggleDrawer('edit-side-drawer');
    }

</script>
