@model List<ServiceAddEditDTO>
@{
    ViewData["Title"] = "Hizmetlerim Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<main class="ml-[240px] pt-16 min-h-screen">
    <div class="p-container_padding max-w-[1280px] mx-auto">
        <!-- Breadcrumb & Title -->
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-stack_lg gap-4">
            <div>
                <h1 class="font-h1 text-h1 text-on-surface">Hizmetlerim</h1>
            </div>
            <button class="bg-primary-container text-on-primary px-6 py-3 rounded-xl font-h3 text-h3 flex items-center gap-2 hover:opacity-90 active:scale-95 transition-all shadow-lg shadow-primary-container/20"
                    onclick="document.getElementById('add-service-modal').classList.remove('hidden')">
                <span class="material-symbols-outlined">add</span>
                Yeni Hizmet Ekle
            </button>
        </div>

        @if (Model != null && Model.Any())
        {
            <!-- Services Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                @foreach (var item in Model)
                {
                    <div class="group bg-surface-container-lowest rounded-2xl border border-outline-variant overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col h-full">
                        <div class="relative h-48 overflow-hidden">
                            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                 src="@(string.IsNullOrEmpty(item.ImageURL) ? "/placeholder.png" : item.ImageURL)" />
                        </div>
                        <div class="p-6 flex-1 flex flex-col">
                            <div class="flex items-start justify-between mb-2">
                                <h3 class="font-h3 text-h3 text-on-surface">@item.Title</h3>
                                @if (item.IsActive)
                                {
                                    <span class="text-green-600 font-label-md bg-green-50 px-2 py-0.5 rounded text-[10px] border border-green-100">AKTİF</span>
                                }
                                else
                                {
                                    <span class="text-tertiary font-label-md bg-tertiary-fixed px-2 py-0.5 rounded text-[10px] border border-outline-variant">PASİF</span>
                                }
                            </div>
                            <p class="font-body-md text-body-md text-on-tertiary-fixed-variant mb-4 line-clamp-2">@item.Description</p>

                            <div class="mt-auto pt-4 border-t border-outline-variant flex items-center justify-between">
                                <div class="flex gap-1">
                                    <!-- Aktif/Pasif Toggle -->
                                    @if (item.IsActive)
                                    {
                                        <form asp-action="MakePassive" asp-controller="Service" asp-area="Admin" method="post" class="inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="p-2 text-secondary hover:text-primary transition-colors hover:bg-primary/10 rounded-lg" title="Pasif Yap">
                                                <span class="material-symbols-outlined">toggle_on</span>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="MakeActive" asp-controller="Service" asp-area="Admin" method="post" class="inline">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="p-2 text-secondary hover:text-success transition-colors hover:bg-primary/10 rounded-lg" title="Aktif Yap">
                                                <span class="material-symbols-outlined">toggle_off</span>
                                            </button>
                                        </form>
                                    }

                                    <button class="p-2 text-secondary hover:text-primary transition-colors hover:bg-primary/10 rounded-lg"
                                            title="Düzenle"
                                            onclick="openEditModal(@item.Id, '@item.Title', '@item.Description', '@item.ImageURL')">
                                        <span class="material-symbols-outlined">edit</span>
                                    </button>
                                </div>

                                <form asp-action="DeleteService" asp-controller="Service" asp-area="Admin" method="post" class="inline"
                                      onsubmit="return confirm('Bu hizmeti silmek istediğinize emin misiniz?');">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="text-error hover:bg-error-container/50 px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1 font-label-md text-label-md">
                                        <span class="material-symbols-outlined text-sm">delete</span>
                                        Sil
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl overflow-hidden">
                <div class="flex flex-col items-center justify-center py-32 px-10">
                    <h3 class="font-h2 text-h2 text-on-surface mb-2">Henüz kayıt bulunmuyor</h3>
                    <p class="text-body-lg text-secondary text-center max-w-md mb-8">
                        Sunduğunuz hizmetleri sergilemek için ilk kaydınızı hemen ekleyin.
                    </p>
                    <button class="flex items-center space-x-2 border-2 border-primary-container text-primary px-8 py-3 rounded-xl font-bold hover:bg-primary-container hover:text-on-primary-container transition-all"
                            onclick="document.getElementById('add-service-modal').classList.remove('hidden')">
                        <span class="material-symbols-outlined">add_circle</span>
                        <span>İlk Hizmeti Ekleyin</span>
                    </button>
                </div>
            </div>
        }
    </div>
</main>

<!-- Add Service Modal -->
<div class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-on-surface/40 backdrop-blur-sm hidden" id="add-service-modal">
    <div class="bg-surface w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden">
        <div class="p-6 border-b border-outline-variant flex justify-between items-center bg-surface-container-low">
            <h2 class="font-h2 text-h2 text-on-surface">Yeni Hizmet Ekle</h2>
            <button class="p-2 hover:bg-surface-container-high rounded-full transition-colors"
                    onclick="document.getElementById('add-service-modal').classList.add('hidden')">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-action="AddService" asp-controller="Service" asp-area="Admin" method="post" enctype="multipart/form-data">
            <div class="p-8 space-y-6 overflow-y-auto max-h-[500px]">
                <div>
                    <label class="block font-label-md text-label-md mb-2 text-on-surface-variant">Hizmet Adı</label>
                    <input class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-primary-container focus:ring-2 focus:ring-primary-container/20 outline-none transition-all font-body-md"
                           name="Title" placeholder="Örn: Web Geliştirme" type="text" required />
                </div>
                <div>
                    <label class="block font-label-md text-label-md mb-2 text-on-surface-variant">Açıklama</label>
                    <textarea class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-primary-container focus:ring-2 focus:ring-primary-container/20 outline-none transition-all font-body-md"
                              name="Description" placeholder="Hizmet detaylarını buraya giriniz..." rows="4" required></textarea>
                </div>
                <div>
                    <label class="block font-label-md text-label-md mb-2 text-on-surface-variant">Görsel</label>
                    <input type="file" name="ImageFile" class="w-full px-4 py-3 rounded-xl border border-outline-variant" />
                </div>
            </div>
            <div class="p-6 border-t border-outline-variant bg-surface-container-lowest flex gap-3 justify-end">
                <button type="button" class="px-6 py-2.5 rounded-xl border border-outline-variant text-on-surface hover:bg-surface-container-high transition-all font-label-md"
                        onclick="document.getElementById('add-service-modal').classList.add('hidden')">
                    İptal
                </button>
                <button type="submit" class="px-8 py-2.5 rounded-xl bg-primary text-on-primary font-bold hover:opacity-90 active:scale-95 transition-all">
                    Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Service Modal -->
<div class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-on-surface/40 backdrop-blur-sm hidden" id="edit-service-modal">
    <div class="bg-surface w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden">
        <div class="p-6 border-b border-outline-variant flex justify-between items-center bg-surface-container-low">
            <h2 class="font-h2 text-h2 text-on-surface">Hizmeti Düzenle</h2>
            <button class="p-2 hover:bg-surface-container-high rounded-full transition-colors"
                    onclick="document.getElementById('edit-service-modal').classList.add('hidden')">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-action="EditService" asp-controller="Service" asp-area="Admin" method="post" enctype="multipart/form-data">
            <div class="p-8 space-y-6 overflow-y-auto max-h-[500px]">
                <input type="hidden" name="Id" id="editServiceId" />
                <input type="hidden" name="ImageURL" id="editServiceImageURL" />

                <div>
                    <label class="block font-label-md text-label-md mb-2 text-on-surface-variant">Hizmet Adı</label>
                    <input class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-primary-container focus:ring-2 focus:ring-primary-container/20 outline-none transition-all font-body-md"
                           name="Title" id="editServiceTitle" type="text" required />
                </div>
                <div>
                    <label class="block font-label-md text-label-md mb-2 text-on-surface-variant">Açıklama</label>
                    <textarea class="w-full px-4 py-3 rounded-xl border border-outline-variant focus:border-primary-container focus:ring-2 focus:ring-primary-container/20 outline-none transition-all font-body-md"
                              name="Description" id="editServiceDescription" rows="4" required></textarea>
                </div>
                <div>
                    <label class="block font-label-md text-label-md mb-2 text-on-surface-variant">Mevcut Görsel</label>
                    <img id="editServiceImagePreview" class="w-32 h-32 object-cover rounded-xl border border-outline-variant mb-3" src="" />
                    <label class="block font-label-md text-label-md mb-2 text-on-surface-variant">Yeni Görsel (opsiyonel)</label>
                    <input type="file" name="ImageFile" class="w-full px-4 py-3 rounded-xl border border-outline-variant" />
                </div>
            </div>
            <div class="p-6 border-t border-outline-variant bg-surface-container-lowest flex gap-3 justify-end">
                <button type="button" class="px-6 py-2.5 rounded-xl border border-outline-variant text-on-surface hover:bg-surface-container-high transition-all font-label-md"
                        onclick="document.getElementById('edit-service-modal').classList.add('hidden')">
                    İptal
                </button>
                <button type="submit" class="px-8 py-2.5 rounded-xl bg-primary text-on-primary font-bold hover:opacity-90 active:scale-95 transition-all">
                    Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openEditModal(id, title, description, imageUrl) {
        document.getElementById('editServiceId').value = id;
        document.getElementById('editServiceTitle').value = title;
        document.getElementById('editServiceDescription').value = description;
        document.getElementById('editServiceImageURL').value = imageUrl;
        document.getElementById('editServiceImagePreview').src = imageUrl || '/placeholder.png';
        document.getElementById('edit-service-modal').classList.remove('hidden');
    }

    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            document.getElementById('add-service-modal').classList.add('hidden');
            document.getElementById('edit-service-modal').classList.add('hidden');
        }
    });
</script>