@model PagedResultDTO<Skill>
@{
    ViewData["Title"] = "Yetenek Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<main class="ml-[240px] pt-16 min-h-screen">
    <div class="p-container_padding max-w-7xl mx-auto">
        <!-- Breadcrumb & Header Action -->
        <div class="flex justify-between items-center mb-8">
            <div>

                <h2 class="font-h1 text-h1 text-on-surface">Yetenek Yönetimi</h2>
            </div>
            <button class="bg-primary-container text-on-primary px-6 py-2.5 rounded-lg flex items-center gap-2 font-semibold shadow-sm hover:opacity-90 active:scale-95 transition-all" onclick="toggleModal(true)">
                <span class="material-symbols-outlined" data-icon="add">add</span>
                Yetenek Ekle
            </button>
        </div>
@if (Model.Items != null && Model.Items.Any())
{
            <!-- Skills Table -->
            <div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-surface-container border-b border-outline-variant">
                                <th class="px-6 py-4 font-semibold text-body-md text-on-surface">Yetenek</th>
                                <th class="px-6 py-4 font-semibold text-body-md text-on-surface">Durum</th>
                                <th class="px-6 py-4 font-semibold text-body-md text-on-surface text-right">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant">
                            @foreach (var item in Model.Items)
                            {
                                <tr class="hover:bg-surface-container-low transition-colors group">

                                    <td class="px-6 py-4">
                                        <p class="font-semibold text-body-md text-on-surface">@item.SkillTitle</p>

                                    </td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="px-3 py-1 bg-secondary-container text-on-success-container rounded-full text-label-md font-semibold">Aktif</span>
                                        }
                                        else
                                        {
                                            <span class="px-3 py-1 bg-danger-container text-on-danger-container rounded-full text-label-md font-semibold">Pasif</span>
                                        }

                                    </td>

                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <button class="p-2 text-on-tertiary-fixed-variant hover:text-primary transition-colors" onclick="openEditModal(@item.Id, '@item.SkillTitle')">
                                                <span class="material-symbols-outlined">edit</span>
                                            </button>
                                            @if (item.IsActive)
                                            {
                                                <form asp-action="MakePassive" asp-controller="Skill" asp-area="Admin" method="post" class="inline">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="p-2 text-on-tertiary-fixed-variant hover:text-error transition-colors">
                                                        <span class="material-symbols-outlined">toggle_on</span>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="MakeActive" asp-controller="Skill" asp-area="Admin" method="post" class="inline">
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="p-2 text-on-tertiary-fixed-variant hover:text-success transition-colors">
                                                        <span class="material-symbols-outlined">toggle_off</span>
                                                    </button>
                                                </form>
                                            }

                                        </div>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
                <div class="px-6 py-4 border-t border-outline-variant flex items-center justify-between">
                    <p class="text-on-surface-variant text-body-md">
                        Toplam @Model.TotalCount yetenek gösteriliyor.
                    </p>
                    <div class="flex gap-2">
                        @if (Model.HasPreviousPage)
                        {
                            <a href="?page=@(Model.CurrentPage - 1)"
                               class="p-2 border border-outline-variant rounded-lg hover:bg-surface-container-high">
                                <span class="material-symbols-outlined">chevron_left</span>
                            </a>
                        }
                        else
                        {
                            <button class="p-2 border border-outline-variant rounded-lg opacity-50" disabled>
                                <span class="material-symbols-outlined">chevron_left</span>
                            </button>
                        }

                        @if (Model.HasNextPage)
                        {
                            <a href="?page=@(Model.CurrentPage + 1)"
                               class="p-2 border border-outline-variant rounded-lg hover:bg-surface-container-high">
                                <span class="material-symbols-outlined">chevron_right</span>
                            </a>
                        }
                        else
                        {
                            <button class="p-2 border border-outline-variant rounded-lg opacity-50" disabled>
                                <span class="material-symbols-outlined">chevron_right</span>
                            </button>
                        }
                    </div>
                </div>
                </div>
}
else
                {


                <!-- Bento Layout Content / Table -->
                <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl overflow-hidden">
                    <!-- Empty State -->
                    <div class="flex flex-col items-center justify-center py-32 px-10" id="empty-state">
                        <div class="w-64 h-64 mb-8">
                        </div>
                        <h3 class="font-h2 text-h2 text-on-surface mb-2">Henüz kayıt bulunmuyor</h3>
                        <p class="text-body-lg text-secondary text-center max-w-md mb-8">Profesyonel kariyerinizi sergilemek için ilk yeteneğinizi hemen ekleyin.</p>

                    </div>
                </div>

                }

            </div>
    </main>
    <!-- Modal Form -->
    <div aria-labelledby="modal-title" aria-modal="true" class="fixed inset-0 z-[60] hidden overflow-y-auto" id="skillModal" role="dialog">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <!-- Background overlay -->
            <div aria-hidden="true" class="fixed inset-0 modal-overlay transition-opacity" onclick="toggleModal(false)"></div>
            <!-- Modal panel -->
            <span aria-hidden="true" class="hidden sm:inline-block sm:align-middle sm:h-screen">​</span>
            <div class="inline-block align-bottom bg-surface-container-lowest rounded-xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-outline-variant">
                <div class="px-8 pt-8 pb-6">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-h2 font-h2 text-on-surface" id="modal-title">Yeni Yetenek Ekle</h3>
                        <button class="text-on-surface-variant hover:text-on-surface transition-all" onclick="toggleModal(false)">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    <form class="space-y-6" asp-action="AddSkill" asp-controller="Skill" asp-asp-area="Admin">
                        <div>
                            <label class="block text-body-md font-semibold text-on-surface mb-2">Yetenek Adı</label>
                            <input class="w-full bg-surface-container-low border border-outline-variant rounded-lg px-4 py-2.5 text-body-md focus:ring-2 focus:ring-primary-container focus:border-primary-container outline-none transition-all" name="SkillTitle" placeholder="Örn: React.js" type="text" required/>
                        </div>

                        <div class="pt-4 border-t border-outline-variant flex gap-4">
                            <button class="flex-1 px-6 py-3 border border-outline-variant text-on-surface font-semibold rounded-lg hover:bg-surface-container-high transition-all" onclick="toggleModal(false)" type="button">
                                İptal
                            </button>
                            <button class="flex-1 px-6 py-3 bg-primary-container text-on-primary font-semibold rounded-lg shadow-sm hover:opacity-90 transition-all" type="submit">
                                Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Form Edit -->
    <div aria-labelledby="modal-title" aria-modal="true" class="fixed inset-0 z-[60] hidden overflow-y-auto" id="skillModalEdit" role="dialog">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <!-- Background overlay -->
            <div aria-hidden="true" class="fixed inset-0 modal-overlay transition-opacity" onclick="toggleModalEdit(false)"></div>
            <!-- Modal panel -->
            <span aria-hidden="true" class="hidden sm:inline-block sm:align-middle sm:h-screen">​</span>
            <div class="inline-block align-bottom bg-surface-container-lowest rounded-xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-outline-variant">
                <div class="px-8 pt-8 pb-6">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-h2 font-h2 text-on-surface" id="modal-title">Yeteneği Düzenle</h3>
                        <button class="text-on-surface-variant hover:text-on-surface transition-all" onclick="toggleModalEdit(false)">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    <form class="space-y-6" asp-action="EditSkill" asp-asp-controller="Skill" asp-asp-area="Admin">
                        <div>
                            <input type="hidden" name="Id" id="editSkillId" />
                            <label class="block text-body-md font-semibold text-on-surface mb-2">Yetenek Adı</label>
                            <input class="w-full bg-surface-container-low border border-outline-variant rounded-lg px-4 py-2.5 text-body-md focus:ring-2 focus:ring-primary-container focus:border-primary-container outline-none transition-all" name="SkillTitle" id="editSkillTitle" type="text" />
                        </div>

                        <div class="pt-4 border-t border-outline-variant flex gap-4">
                            <button class="flex-1 px-6 py-3 border border-outline-variant text-on-surface font-semibold rounded-lg hover:bg-surface-container-high transition-all" onclick="toggleModal(false)" type="button">
                                İptal
                            </button>
                            <button class="flex-1 px-6 py-3 bg-primary-container text-on-primary font-semibold rounded-lg shadow-sm hover:opacity-90 transition-all" type="submit">
                                Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>



    <script>

        function toggleModal(show) {
            const modal = document.getElementById('skillModal');
            if (show) {
                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            } else {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }
        }
         // Close modal on escape key
            window.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') toggleModal(false);
            });
            //Edit Skill Functions
              function toggleModalEdit(show) {
            const modal = document.getElementById('skillModalEdit');
            if (show) {
                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            } else {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
            }
        }
         // Close modal on escape key
            window.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') toggleModalEdit(false);
            });

            function openEditModal(id, title) {
            document.getElementById('editSkillId').value = id;
            document.getElementById('editSkillTitle').value = title;
            toggleModalEdit(true);
        }
    </script>
