@{
    ViewData["Title"] = "Ayarlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<main class="ml-[240px] pt-16 min-h-screen">
    <div class="p-container_padding max-w-2xl mx-auto">
        <h1 class="font-h1 text-h1 text-on-surface mb-8">Hesap Ayarları</h1>

        @if (TempData["Success"] != null)
        {
            <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined text-green-600">check_circle</span>
                <p class="text-green-700 font-body-md">@TempData["Success"]</p>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined text-red-600">error</span>
                <p class="text-red-700 font-body-md">@TempData["Error"]</p>
            </div>
        }

        <form asp-action="UpdateCredentials" asp-controller="Settings" asp-area="Admin" method="post">
            <div class="space-y-6">

                <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
                    <h3 class="font-h3 text-h3 text-on-surface mb-4">Kullanıcı Adı</h3>
                    <div>
                        <label class="block font-label-md text-label-md text-on-surface-variant mb-2">Yeni Kullanıcı Adı</label>
                        <input class="w-full px-4 py-3 rounded-lg border border-outline-variant focus:ring-2 focus:ring-primary-container outline-none font-body-md"
                               name="NewUsername" type="text" placeholder="Yeni kullanıcı adı" />
                    </div>
                </div>

                <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6">
                    <h3 class="font-h3 text-h3 text-on-surface mb-4">Şifre Değiştir</h3>
                    <div class="space-y-4">
                        <div class="relative">
                            <input class="w-full px-4 py-3 pr-12 rounded-lg border border-outline-variant focus:ring-2 focus:ring-primary-container outline-none font-body-md"
                                   name="CurrentPassword" id="currentPassword" type="password" placeholder="Mevcut Şifre" />
                            <button type="button" onclick="togglePassword('currentPassword', 'eyeCurrent')"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-secondary hover:text-primary transition-colors">
                                <span class="material-symbols-outlined" id="eyeCurrent">visibility</span>
                            </button>
                        </div>

                        <div class="relative">
                            <input class="w-full px-4 py-3 pr-12 rounded-lg border border-outline-variant focus:ring-2 focus:ring-primary-container outline-none font-body-md"
                                   name="NewPassword" id="newPassword" type="password" placeholder="Yeni Şifre" />
                            <button type="button" onclick="togglePassword('newPassword', 'eyeNew')"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-secondary hover:text-primary transition-colors">
                                <span class="material-symbols-outlined" id="eyeNew">visibility</span>
                            </button>
                        </div>

                        <div class="relative">
                            <input class="w-full px-4 py-3 pr-12 rounded-lg border border-outline-variant focus:ring-2 focus:ring-primary-container outline-none font-body-md"
                                   name="ConfirmPassword" id="confirmPassword" type="password" placeholder="Yeni Şifre Tekrar" />
                            <button type="button" onclick="togglePassword('confirmPassword', 'eyeConfirm')"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-secondary hover:text-primary transition-colors">
                                <span class="material-symbols-outlined" id="eyeConfirm">visibility</span>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end">
                    <button type="submit"
                            class="px-10 py-3 bg-primary-container text-on-primary font-bold rounded-xl hover:brightness-110 shadow-sm transition-all active:scale-95">
                        Kaydet
                    </button>
                </div>

            </div>
        </form>
    </div>
</main>
<script>
        function togglePassword(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        if (input.type === 'password') {
            input.type = 'text';
            icon.textContent = 'visibility_off';
        } else {
            input.type = 'password';
            icon.textContent = 'visibility';
        }
    }
</script>