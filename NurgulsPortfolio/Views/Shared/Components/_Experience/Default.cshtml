@model List<Experience>
@{
    Layout = null;
}
<section id="experience" class="py-24">
    <div class="max-w-6xl mx-auto px-6">
        <p class="reveal text-xs font-medium text-accent tracking-widest uppercase mb-3">Kariyer</p>
        <h2 class="reveal d1 font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white mb-14">Eğitim &amp; Deneyim</h2>

        <div class="grid md:grid-cols-2 gap-12">

            <!-- Deneyim -->
            <div>
                <h3 class="reveal font-display font-bold text-2xl text-zinc-900 dark:text-white mb-8 flex items-center gap-3">
                    <span class="w-8 h-8 bg-accent/10 rounded-lg flex items-center justify-center">
                        <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </span>
                    Deneyim
                </h3>
                <div class="space-y-6">
                    @foreach (var item in Model)
                    {
                        <div class="reveal card-h group bg-white dark:bg-zinc-900 rounded-2xl p-6 border border-zinc-100 dark:border-zinc-800 hover:border-accent">
                            <div class="flex items-start justify-between mb-2">
                                <div>
                                    <h4 class="font-display font-bold text-lg text-zinc-900 dark:text-white">@item.Position</h4>
                                    <p class="text-sm text-accent font-medium">@item.Company</p>
                                </div>
                                <span class="text-xs text-zinc-400 dark:text-zinc-500 bg-zinc-100 dark:bg-zinc-800 px-3 py-1 rounded-full whitespace-nowrap">
                                    @item.StartDate.ToString("MMM yyyy") —
                                    @(item.EndDate == null ? "Günümüz" : item.EndDate.Value.ToString("MMM yyyy"))
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(item.Location))
                            {
                                <p class="text-xs text-zinc-400 dark:text-zinc-500 mb-3 flex items-center gap-1">
                                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    </svg>
                                    @item.Location
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(item.Description))
                            {
                                <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">@item.Description</p>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Eğitim -->
            <div>
                <h3 class="reveal font-display font-bold text-2xl text-zinc-900 dark:text-white mb-8 flex items-center gap-3">
                    <span class="w-8 h-8 bg-accent/10 rounded-lg flex items-center justify-center">
                        <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                        </svg>
                    </span>
                    Eğitim
                </h3>
                <div class="space-y-6">
                    @foreach (var item in ViewBag.Education as List<Education>)
                    {
                        <div class="reveal card-h group bg-white dark:bg-zinc-900 rounded-2xl p-6 border border-zinc-100 dark:border-zinc-800 hover:border-accent">
                            <div class="flex items-start justify-between mb-2">
                                <div>
                                    <h4 class="font-display font-bold text-lg text-zinc-900 dark:text-white">@item.Department</h4>
                                    <p class="text-sm text-accent font-medium">@item.School</p>
                                </div>
                                <span class="text-xs text-zinc-400 dark:text-zinc-500 bg-zinc-100 dark:bg-zinc-800 px-3 py-1 rounded-full whitespace-nowrap">
                                    @item.StartDate.ToString("MMM yyyy") —
                                    @(item.EndDate == null ? "Günümüz" : item.EndDate.Value.ToString("MMM yyyy"))
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</section>