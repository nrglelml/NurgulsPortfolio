@model Project
@{
    Layout = null;
}

<div class="md:col-span-2 bg-surface-container-lowest rounded-xl border border-outline-variant p-6 hover:shadow-xl transition-all duration-300">
    <h3 class="font-h3 text-h3 text-on-surface mb-4">En Son Eklenen Proje</h3>
    @if (Model == null)
    {
        <p class="text-secondary font-body-md">Henüz proje eklenmedi.</p>
    }
    else
    {
        <div class="h-48 w-full rounded-lg bg-surface-container overflow-hidden mb-4">
            <img class="w-full h-full object-cover" data-alt="A cinematic, high-contrast showcase of a modern web application dashboard. The interface is clean, displaying complex data visualizations and elegant UI components. The color scheme is professional with dark grays and vibrant orange highlights, set against a soft, bright office background with light bokeh effects. It looks like a high-end SaaS product advertisement." src="@Model.CoverImageURL" />
        </div>
        <div class="flex justify-between items-end">
            <div>
                <h4 class="font-body-lg text-body-lg font-bold text-on-surface">@Model.ProjectTitle</h4>
                <p class="font-body-md text-body-md text-secondary">@Model.Skill.SkillTitle @Model.TechStack</p>
            </div>
            <a class="p-2 bg-primary-container/10 text-primary-container rounded-full hover:bg-primary-container hover:text-on-primary transition-all" href="/Admin/Project/Index">
                <span class="material-symbols-outlined">arrow_forward</span>
            </a>
        </div>
    }
</div>