@model AboutMe
@{
    Layout = null;
}
<div class="flex items-center gap-3 pl-4 border-l border-outline-variant">
    <div class="text-right hidden sm:block">
        <p class="font-label-md text-label-md text-on-surface">
            @(Model == null || string.IsNullOrEmpty(Model.Name) ? "Admin" : Model.Name + " " + Model.Surname)
        </p>
        <p class="font-label-md text-label-md text-secondary opacity-70">Admin</p>
    </div>
    <img class="w-10 h-10 rounded-full border-2 border-primary-container/20 object-cover"
         src="@(string.IsNullOrEmpty(Model.ImageURL) ? "/woman.png" : Model.ImageURL)"
</div>
