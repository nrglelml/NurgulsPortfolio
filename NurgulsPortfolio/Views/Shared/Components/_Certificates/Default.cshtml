@model List<Certificate>
@{
    Layout = null;
}
<section id="certificates" class="py-24">
    <div class="max-w-6xl mx-auto px-6">
        <p class="reveal text-xs font-medium text-accent tracking-widest uppercase mb-3">Sertifikalar</p>
        <h2 class="reveal d1 font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white mb-14">Kurs Sertifikaları</h2>

        @if (Model != null && Model.Any())
        {
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var item in Model)
                {
                    <div class="reveal card-h group bg-white dark:bg-zinc-900 rounded-2xl p-6 border border-zinc-100 dark:border-zinc-800 hover:border-accent">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
                                 style="background-color: @(item.IconBgColor ?? "#f4f4f5")">
                                <i class="@(item.IconClass ?? "bi bi-award") text-white text-xl"></i>
                            </div>
                            <div>
                                <h3 class="font-display font-bold text-lg text-zinc-900 dark:text-white leading-tight">@item.Issuer</h3>
                                @if (!string.IsNullOrEmpty(item.Category))
                                {
                                    <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5">@item.Category</p>
                                }
                            </div>
                        </div>

                        <div class="flex items-center justify-between text-xs text-zinc-400 dark:text-zinc-500 mt-4 pt-4 border-t border-zinc-100 dark:border-zinc-800">
                            <span>
                                @if (item.IssueDate != null)
                                {
                                    @item.IssueDate.Value.ToString("MMM yyyy")
                                }
                            </span>
                            <span>
                                @if (item.ExpiryDate != null)
                                {
                                    <text>Bitiş: @item.ExpiryDate.Value.ToString("MMM yyyy")</text>
                                }
                                else
                                {
                                    <span class="text-green-500 font-medium">Süresiz</span>
                                }
                            </span>
                        </div>

                        @if (!string.IsNullOrEmpty(item.CredentialURL))
                        {
                            <a href="@item.CredentialURL" target="_blank"
                               class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-accent hover:underline">
                                Sertifikayı Görüntüle
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                            </a>
                        }
                    </div>
                }
            </div>
        }
    </div>
</section>