@{
    Layout = null;
}
<div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden flex flex-col">
    <div class="p-6 border-b border-outline-variant">
        <h3 class="font-h3 text-h3 text-on-surface">Portfolyo Görünürlüğü</h3>
    </div>
    <div class="p-6 flex-1 relative min-h-[300px]">

        <div class="relative z-10 space-y-6">
            <div class="bg-on-surface/5 backdrop-blur-md p-4 rounded-lg border border-outline-variant">
                <div class="flex justify-between items-center mb-2">
                    <span class="font-label-md text-label-md text-secondary">Site Trafiği</span>
                    <span class="text-primary font-bold">+12%</span>
                </div>
                <div class="w-full bg-outline-variant/30 h-2 rounded-full overflow-hidden">
                    <div class="bg-primary-container h-full w-[75%]"></div>
                </div>
            </div>
            <div class="bg-on-surface/5 backdrop-blur-md p-4 rounded-lg border border-outline-variant">
                <div class="flex justify-between items-center mb-2">
                    <span class="font-label-md text-label-md text-secondary">Proje Etkileşimi</span>
                    <span class="text-primary font-bold">+8%</span>
                </div>
                <div class="w-full bg-outline-variant/30 h-2 rounded-full overflow-hidden">
                    <div class="bg-primary-container h-full w-[60%]"></div>
                </div>
            </div>
            <div class="bg-on-surface/5 backdrop-blur-md p-4 rounded-lg border border-outline-variant">
                <div class="flex justify-between items-center mb-2">
                    <span class="font-label-md text-label-md text-secondary">CV İndirme</span>
                    <span class="text-primary font-bold">+5%</span>
                </div>
                <div class="w-full bg-outline-variant/30 h-2 rounded-full overflow-hidden">
                    <div class="bg-primary-container h-full w-[45%]"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="p-6 bg-surface-container border-t border-outline-variant">
        <p class="font-label-md text-label-md text-secondary text-center italic">Son 30 günlük veriler baz alınmıştır.</p>
    </div>
</div>