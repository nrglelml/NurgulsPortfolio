@model Testimonials
@{
    ViewData["Title"] = "Referans Oluştur";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-24 bg-zinc-50 dark:bg-zinc-900/40 min-h-screen">
    <div class="max-w-2xl mx-auto px-6">
        <div class="text-center mb-12">
            <p class="text-xs font-medium text-accent tracking-widest uppercase mb-3">Referans</p>
            <h1 class="font-display font-bold text-4xl text-zinc-900 dark:text-white mb-4">Görüşünüzü Paylaşın</h1>
            <p class="text-zinc-500 dark:text-zinc-400">Birlikte çalışmaktan memnun kaldıysanız referans bırakabilirsiniz.</p>
        </div>
        @if (TempData["Success"] != null)
        {
            <div class="mb-4 p-4 bg-green-500/10 border border-green-500/20 rounded-xl">
                <p class="text-green-400 text-sm font-medium">✓ @TempData["Success"]</p>
            </div>
        }

        @if (TempData["ValidationErrors"] != null)
        {
            <div class="mb-4 p-4 bg-red-500/10 border border-red-500/20 rounded-xl">
                @foreach (var error in TempData["ValidationErrors"].ToString().Split("|"))
                {
                    <p class="text-red-400 text-sm">• @error</p>
                }
            </div>
        }


        <div class="bg-white dark:bg-zinc-900 rounded-3xl p-8 border border-zinc-100 dark:border-zinc-800 shadow-sm">
            <form asp-action="AddTestimonial" asp-controller="Testimonial" method="post" novalidate>
                <div class="flex flex-col gap-6">

                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-2">Ad Soyad *</label>
                            <input type="text" asp-for="Name"
                                   class="w-full bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-zinc-900 dark:text-white text-sm rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors" />
                            <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-2">Ünvan / Şirket *</label>
                            <input type="text" asp-for="Title"
                                   class="w-full bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-zinc-900 dark:text-white text-sm rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors" />
                            <span asp-validation-for="Title" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-2">Yorumunuz *</label>
                        <textarea asp-for="MessageBody" rows="5"
                                  class="w-full bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 text-zinc-900 dark:text-white text-sm rounded-xl px-4 py-3 focus:outline-none focus:border-accent transition-colors resize-none"
                                  placeholder="Birlikte çalışma deneyiminizi paylaşın..."></textarea>
                        <span asp-validation-for="MessageBody" class="text-red-500 text-xs mt-1 block"></span>
                    </div>


                    <button type="submit"
                            class="shimmer w-full bg-accent text-white font-display font-bold text-sm py-3.5 rounded-xl hover:bg-accent-light transition-colors">
                        Referans Gönder →
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

