@model ContactMe
@if (TempData["Success"] != null)
{
    <div class="mb-4 p-4 bg-green-500/10 border border-green-500/20 rounded-xl">
        <p class="text-green-400 text-sm font-medium">✓ @TempData["Success"]</p>
    </div>
}

@if (TempData["ValidationErrors"] != null)
{
    <div class="mb-4 p-4 bg-red-500/10 border border-red-500/20 rounded-xl">
        @foreach (var error in TempData["ValidationErrors"].ToString().Split("|"))
        {
            <p class="text-red-400 text-sm">• @error</p>
        }
    </div>
}
@if (TempData["CaptchaError"] != null)
{
    <div class="alert alert-danger">@TempData["CaptchaError"]</div>
}
<form asp-action="SendMessage" asp-controller="Home" method="post" novalidate>
    <div class="flex flex-col gap-4">
        <div class="grid sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-xs font-medium text-zinc-400 mb-1.5">İsim <span>*</span></label>
                <input type="text" asp-for="Name"
                       class="w-full bg-zinc-800 border border-zinc-700 text-white text-sm rounded-xl px-4 py-3 placeholder-zinc-600 focus:outline-none focus:border-accent transition-colors" />
                <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
            </div>
            <div>
                <label class="block text-xs font-medium text-zinc-400 mb-1.5">Mail </label>
                <input type="email" asp-for="Mail"
                       class="w-full bg-zinc-800 border border-zinc-700 text-white text-sm rounded-xl px-4 py-3 placeholder-zinc-600 focus:outline-none focus:border-accent transition-colors" />
                
            </div>
        </div>
        <div>
            <label class="block text-xs font-medium text-zinc-400 mb-1.5">Konu <span>*</span></label>
            <input type="text" asp-for="Subject"
                   class="w-full bg-zinc-800 border border-zinc-700 text-white text-sm rounded-xl px-4 py-3 placeholder-zinc-600 focus:outline-none focus:border-accent transition-colors" />
            <span asp-validation-for="Subject" class="text-red-500 text-xs mt-1"></span>
        </div>
        <div>
            <label class="block text-xs font-medium text-zinc-400 mb-1.5">Mesaj <span>*</span></label>
            <textarea asp-for="MessageBody" rows="4"
                      class="w-full bg-zinc-800 border border-zinc-700 text-white text-sm rounded-xl px-4 py-3 placeholder-zinc-600 focus:outline-none focus:border-accent transition-colors resize-none"></textarea>
            <span asp-validation-for="MessageBody" class="text-red-500 text-xs mt-1"></span>
        </div>
        <button type="submit" class="shimmer w-full bg-accent text-white font-display font-bold text-sm py-3.5 rounded-xl hover:bg-accent-light transition-colors">
            Gönder →
        </button>
    </div>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>

    <div class="g-recaptcha" data-sitekey="6Lf4q1MtAAAAAJ_3etvddb5v8LriDzMG_Une169n"></div>
</form>